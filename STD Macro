local function AdvancedUpgrade(TargetName)
   if not UpgradeTowerFunction then return end
   
   -- 1. Check Standard Workspace Folders
   local Workspace = game:GetService("Workspace")
   local folders = {Workspace:FindFirstChild("Towers"), Workspace:FindFirstChild("PlacedTowers"), Workspace:FindFirstChild("Units"), Workspace}
   
   for _, folder in pairs(folders) do
      if folder then
         for _, Object in pairs(folder:GetChildren()) do
            if Object and Object.Name and string.find(string.lower(Object.Name), string.lower(TargetName)) then
               task.spawn(function()
                  UpgradeTowerFunction:InvokeServer(Object)
               end)
               task.wait(0.01)
            end
         end
      end
   end
   
   -- 2. Fallback to Nil Memory
   if getnilinstances then
      for _, Object in pairs(getnilinstances()) do
         if Object and Object.Name and string.find(string.lower(Object.Name), string.lower(TargetName)) then
            task.spawn(function()
               UpgradeTowerFunction:InvokeServer(Object)
            end)
            task.wait(0.01)
         end
      end
   end
end


